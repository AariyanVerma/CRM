generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String               @id @default(cuid())
  email                 String               @unique
  passwordHash          String
  role                  UserRole             @default(STAFF)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  address               String?
  firstName             String?
  lastName              String?
  phoneNumber           String?
  profileImageUrl       String?
  dailyPrices           DailyPrice[]
  passwordResetOTPs     PasswordResetOTP[]
  passwordResetTokens   PasswordResetToken[]
  completedTransactions Transaction[]        @relation("CompletedTransactions")
  createdTransactions   Transaction[]        @relation("CreatedTransactions")
  transactionAuditLogs  TransactionAuditLog[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetOTP {
  id        String   @id @default(cuid())
  userId    String
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([otp])
  @@index([expiresAt])
}

model Customer {
  id                        String           @id @default(cuid())
  fullName                  String
  phoneNumber               String
  address                   String
  isBusiness                Boolean          @default(false)
  businessName              String?
  businessVerificationNotes String?
  identityVerified          Boolean          @default(false)
  identityVerificationNotes String?
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt
  cards                     MembershipCard[]
  transactions              Transaction[]
}

model MembershipCard {
  id            String     @id @default(cuid())
  token         String     @unique
  customerId    String
  status        CardStatus @default(ACTIVE)
  issuedAt      DateTime   @default(now())
  lastScannedAt DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  customer      Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([customerId])
}

model Transaction {
  id                String            @id @default(cuid())
  customerId        String
  createdByUserId   String
  type              TransactionType
  status            TransactionStatus @default(OPEN)
  goldSpot          Float
  silverSpot        Float
  platinumSpot      Float
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  completedAt       DateTime?
  completedByUserId String?
  lineItems         LineItem[]
  completedBy       User?             @relation("CompletedTransactions", fields: [completedByUserId], references: [id])
  createdBy         User              @relation("CreatedTransactions", fields: [createdByUserId], references: [id])
  customer          Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([type, status])
}

model LineItem {
  id               String      @id @default(cuid())
  transactionId    String
  metalType        MetalType
  purityLabel      String
  dwt              Float       @default(0)
  pricePerOz       Float       @default(0)
  lineTotal        Float       @default(0)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  purityPercentage Float?
  transaction      Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
}

model DailyPrice {
  id                      String   @id @default(cuid())
  date                    DateTime @unique @db.Date
  gold                    Float
  silver                  Float
  platinum                Float
  createdByUserId         String
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  scrapGoldPercentage     Float    @default(95)
  scrapSilverPercentage   Float    @default(95)
  scrapPlatinumPercentage Float    @default(95)
  meltGoldPercentage      Float    @default(95)
  meltSilverPercentage    Float    @default(95)
  meltPlatinumPercentage  Float    @default(95)
  createdBy               User     @relation(fields: [createdByUserId], references: [id])

  @@index([date])
}

enum UserRole {
  STAFF
  ADMIN
}

enum CardStatus {
  ACTIVE
  LOST
  DISABLED
}

enum TransactionType {
  SCRAP
  MELT
}

enum TransactionStatus {
  OPEN
  PRINTED
  VOID
}

enum MetalType {
  GOLD
  SILVER
  PLATINUM
}

model TransactionAuditLog {
  id             String   @id @default(cuid())
  transactionId  String
  userId         String
  action         String   // STATUS_CHANGE | MOVE | DELETE
  oldValue       String?  // JSON snapshot of relevant old data
  newValue       String?  // JSON snapshot of relevant new data
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([userId])
  @@index([createdAt])
}
