generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ProfileImageUpload {
  id        String   @id @default(cuid())
  data      Bytes
  mimeType  String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model User {
  id                         String               @id @default(cuid())
  email                      String               @unique
  passwordHash               String
  role                       UserRole             @default(STAFF)
  canIssueCard               Boolean              @default(false)
  canAccessLockedCards       Boolean              @default(false)
  inactivityTimeoutMinutes  Int?
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt
  address                    String?
  firstName                  String?
  lastName                   String?
  phoneNumber                String?
  profileImageUrl            String?
  dailyPrices                DailyPrice[]
  passwordResetOTPs          PasswordResetOTP[]
  passwordResetTokens        PasswordResetToken[]
  completedTransactions      Transaction[]        @relation("CompletedTransactions")
  createdTransactions        Transaction[]        @relation("CreatedTransactions")
  transactionAuditLogs       TransactionAuditLog[]
  uploadedDocuments          CustomerDocument[]
  userCards                  UserCard[]
  approvalRequestsSent       TransactionApprovalRequest[] @relation("ApprovalRequestsSent")
  approvalRequestsReceived   TransactionApprovalRequest[] @relation("ApprovalRequestsReceived")
}

model UserCard {
  id                     String     @id @default(cuid())
  userId                 String
  token                  String     @unique
  scanSlug               String     @unique
  status                 CardStatus @default(ACTIVE)
  locked                 Boolean    @default(false)
  lockedAt               DateTime?
  tagPermanentlyLockedAt DateTime?
  issuedAt               DateTime   @default(now())
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
  user                   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([scanSlug])
  @@index([token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetOTP {
  id        String   @id @default(cuid())
  userId    String
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([otp])
  @@index([expiresAt])
}

model Customer {
  id                        String             @id @default(cuid())
  fullName                  String
  phoneNumber               String
  address                   String
  isBusiness                Boolean            @default(false)
  businessName              String?
  businessVerificationNotes String?
  identityVerified          Boolean            @default(false)
  identityVerificationNotes String?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt
  cards                     MembershipCard[]
  transactions              Transaction[]
  documents                 CustomerDocument[]
}

model CustomerDocument {
  id          String   @id @default(cuid())
  customerId  String
  name        String
  mimeType    String
  size        Int
  data        Bytes
  uploadedAt  DateTime @default(now())
  uploadedBy  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  uploader    User     @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([uploadedBy])
}

model MembershipCard {
  id                     String     @id @default(cuid())
  token                  String     @unique
  scanSlug               String?    @unique
  customerId             String
  status                 CardStatus @default(ACTIVE)
  locked                 Boolean    @default(false)
  lockedAt               DateTime?
  tagPermanentlyLockedAt DateTime?
  issuedAt               DateTime   @default(now())
  lastScannedAt          DateTime?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
  customer               Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([scanSlug])
  @@index([customerId])
}

model Transaction {
  id                String            @id @default(cuid())
  customerId        String
  createdByUserId   String
  type              TransactionType
  status            TransactionStatus @default(OPEN)
  goldSpot          Float
  silverSpot        Float
  platinumSpot      Float
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  completedAt       DateTime?
  completedByUserId String?
  lineItems         LineItem[]
  completedBy       User?             @relation("CompletedTransactions", fields: [completedByUserId], references: [id])
  createdBy         User              @relation("CreatedTransactions", fields: [createdByUserId], references: [id])
  customer          Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  approvalRequests  TransactionApprovalRequest[]

  @@index([customerId])
  @@index([type, status])
}

model LineItem {
  id               String      @id @default(cuid())
  transactionId    String
  metalType        MetalType
  purityLabel      String
  dwt              Float       @default(0)
  pricePerOz       Float       @default(0)
  lineTotal        Float       @default(0)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  purityPercentage Float?
  transaction      Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
}

model DailyPrice {
  id                      String   @id @default(cuid())
  date                    DateTime @unique @db.Date
  gold                    Float
  silver                  Float
  platinum                Float
  createdByUserId         String
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  scrapGoldPercentage     Float    @default(95)
  scrapSilverPercentage   Float    @default(95)
  scrapPlatinumPercentage Float    @default(95)
  meltGoldPercentage      Float    @default(95)
  meltSilverPercentage    Float    @default(95)
  meltPlatinumPercentage  Float    @default(95)
  createdBy               User     @relation(fields: [createdByUserId], references: [id])

  @@index([date])
}

enum UserRole {
  STAFF
  ADMIN
}

enum CardStatus {
  ACTIVE
  LOST
  DISABLED
}

enum TransactionType {
  SCRAP
  MELT
}

enum TransactionStatus {
  OPEN
  PENDING_APPROVAL
  APPROVED
  PRINTED
  VOID
}

enum ApprovalRequestStatus {
  PENDING
  APPROVED
  DENIED
}

model TransactionApprovalRequest {
  id                String                 @id @default(cuid())
  transactionId     String
  requestedByUserId String
  requestedToUserId String
  status            ApprovalRequestStatus  @default(PENDING)
  approvalGroupId   String?
  createdAt         DateTime               @default(now())
  respondedAt       DateTime?
  adminEditedAt     DateTime?
  transaction       Transaction            @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  requestedBy       User                   @relation("ApprovalRequestsSent", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  requestedTo       User                   @relation("ApprovalRequestsReceived", fields: [requestedToUserId], references: [id], onDelete: Cascade)

  @@unique([transactionId, requestedByUserId])
  @@index([requestedToUserId, status])
  @@index([transactionId])
  @@index([approvalGroupId])
}

enum MetalType {
  GOLD
  SILVER
  PLATINUM
}

model TransactionAuditLog {
  id             String   @id @default(cuid())
  transactionId  String
  userId         String
  action         String
  oldValue       String?
  newValue       String?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([userId])
  @@index([createdAt])
}

model StonesSave {
  id        String         @id @default(cuid())
  createdAt DateTime       @default(now())
  rows      StonesSaveRow[]
}

model StonesSaveRow {
  id           String     @id @default(cuid())
  stonesSaveId String
  date         DateTime   @db.Date
  metal        MetalType
  purity       String
  dwt          Float
  pricePaid    Float
  stonesSave   StonesSave @relation(fields: [stonesSaveId], references: [id], onDelete: Cascade)

  @@index([stonesSaveId])
  @@index([date])
}

enum StonesReportPeriod {
  DAY
  WEEK
  MONTH
  SIX_MONTHS
  YEAR
}

model StonesReport {
  id                String             @id @default(cuid())
  createdAt         DateTime           @default(now())
  periodType        StonesReportPeriod
  periodStart       DateTime           @db.Date
  periodEnd         DateTime           @db.Date
  totalPaid         Float
  grandTotal        Float
  profit            Float
  selectedRowIds    String?
  selectedRowsData  Json?
}
